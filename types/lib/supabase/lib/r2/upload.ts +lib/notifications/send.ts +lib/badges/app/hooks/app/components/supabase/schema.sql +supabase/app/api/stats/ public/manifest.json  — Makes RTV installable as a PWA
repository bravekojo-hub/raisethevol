// ════════════════════════════════════════════════════════════
// app/sitemap.ts  — Dynamic sitemap
// ════════════════════════════════════════════════════════════
import type { MetadataRoute } from 'next'

export default function sitemap(): MetadataRoute.Sitemap {
  return [
    { url: 'https://www.raisethevol.com', lastModified: new Date(), changeFrequency: 'daily', priority: 1 },
    { url: 'https://www.raisethevol.com/feed', lastModified: new Date(), changeFrequency: 'always', priority: 0.9 },
    { url: 'https://www.raisethevol.com/speak', lastModified: new Date(), changeFrequency: 'monthly', priority: 0.8 },
    { url: 'https://www.raisethevol.com/discover', lastModified: new Date(), changeFrequency: 'daily', priority: 0.8 },
    { url: 'https://www.raisethevol.com/privacy', lastModified: new Date(), changeFrequency: 'monthly', priority: 0.4 },
    { url: 'https://www.raisethevol.com/login', lastModified: new Date(), changeFrequency: 'monthly', priority: 0.5 },
    { url: 'https://www.raisethevol.com/signup', lastModified: new Date(), changeFrequency: 'monthly', priority: 0.6 },
  ]
}
