        className="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm resize-none outline-none focus:border-[#AFA9EC] transition leading-relaxed min-h-[100px] bg-gray-50"/>
      <div className="flex justify-end text-xs text-gray-400 mt-1 mb-3">{content.length} / 500</div>

      <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">How are you feeling?</p>
      <div className="flex flex-wrap gap-2 mb-4">
        {MOODS.map(m => (
          <button key={m} onClick={() => setMood(mood === m ? '' : m)}
            className={`px-3 py-1.5 rounded-full text-xs border transition ${mood === m ? 'bg-[#EEEDFE] border-[#AFA9EC] text-[#534AB7]' : 'bg-gray-50 border-gray-200 text-gray-500'}`}>
