// ════════════════════════════════════════════════════════════
// components/speak/VoiceRecorder.tsx
// ════════════════════════════════════════════════════════════
'use client'
import { useState, useRef } from 'react'
import type { Audience } from '@/types'

const TOPICS = ['Mental health','Relationships','Faith & spirituality','Career','Celebration','Family']

interface Props { onPublish: (payload: any, blob: Blob, filename: string) => void; publishing: boolean }

export default function VoiceRecorder({ onPublish, publishing }: Props) {
  const [recording, setRecording] = useState(false)
  const [recorded, setRecorded] = useState<{ blob: Blob; duration: number } | null>(null)
  const [seconds, setSeconds] = useState(0)
  const [topic, setTopic] = useState('')
  const [audience, setAudience] = useState<Audience>('everyone')
  const mrRef = useRef<MediaRecorder | null>(null)
  const chunksRef = useRef<Blob[]>([])
  const timerRef = useRef<ReturnType<typeof setInterval>>()
  const startRef = useRef(0)

  async function startRecording() {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true })
    const mr = new MediaRecorder(stream)
    mrRef.current = mr; chunksRef.current = []
    mr.ondataavailable = e => chunksRef.current.push(e.data)
    mr.onstop = () => {
      const blob = new Blob(chunksRef.current, { type: 'audio/webm' })
      setRecorded({ blob, duration: Math.round((Date.now() - startRef.current) / 1000) })
      stream.getTracks().forEach(t => t.stop())
    }
    mr.start(); startRef.current = Date.now()
    setRecording(true); setSeconds(0)
    timerRef.current = setInterval(() => {
      setSeconds(s => { if (s >= 299) { stopRecording(); return s } return s + 1 })
    }, 1000)
  }

  function stopRecording() {
    mrRef.current?.stop(); clearInterval(timerRef.current); setRecording(false)
  }

  function fmt(s: number) { return `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}` }

  function submit() {
    if (!recorded) return
    onPublish({ type: 'voice', audience, topic, media_duration: recorded.duration, is_anonymous: false }, recorded.blob, `voice-${Date.now()}.webm`)
  }

  return (
    <div>
      <div className="bg-gray-50 border border-gray-200 rounded-2xl p-6 text-center mb-4">
        <div onClick={recording ? stopRecording : startRecording}
          className={`w-20 h-20 rounded-full border-2 flex items-center justify-center mx-auto mb-3.5 cursor-pointer transition ${recording ? 'border-[#D85A30] animate-pulse' : 'border-gray-200'}`}>
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke={recording ? '#D85A30' : '#9999bb'} strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/>
          </svg>
        </div>
        <p className="text-sm text-gray-500 mb-1">{recording ? 'Recording... tap to stop' : recorded ? 'Recording saved — ready to publish' : 'Tap to start recording'}</p>
        <p className="text-3xl font-bold font-syne text-[#1a1a2e] mb-2">{fmt(seconds)}</p>
        <div className="h-1 bg-gray-200 rounded-full max-w-[200px] mx-auto overflow-hidden">
          <div className="h-full bg-[#7F77DD] rounded-full transition-all" style={{ width: `${(seconds / 300) * 100}%` }}/>
        </div>
        <p className="text-xs text-gray-400 mt-2">Max 5 minutes</p>
      </div>

      <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Topic (optional)</p>
      <div className="flex flex-wrap gap-2 mb-4">
        {TOPICS.map(t => (
          <button key={t} onClick={() => setTopic(topic === t ? '' : t)}
            className={`px-3 py-1.5 rounded-full text-xs border transition ${topic === t ? 'bg-[#EEEDFE] border-[#AFA9EC] text-[#534AB7]' : 'bg-gray-50 border-gray-200 text-gray-500'}`}>
            {t}
          </button>
        ))}
      </div>

      <button onClick={submit} disabled={!recorded || publishing}
        className="w-full bg-[#7F77DD] text-white rounded-xl py-3 font-semibold font-syne text-sm hover:bg-[#534AB7] transition disabled:opacity-50">
        {publishing ? 'Uploading & publishing...' : 'Publish voice note'}
      </button>
    </div>
  )
}


