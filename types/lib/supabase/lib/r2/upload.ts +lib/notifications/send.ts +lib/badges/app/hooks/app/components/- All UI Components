interface Props { url: string; thumbnail?: string | null; topic?: string | null; duration: number }

function fmt(s: number) { return `${Math.floor(s/60)}:${String(Math.floor(s%60)).padStart(2,'0')}` }

export default function VideoThumb({ url, thumbnail, topic, duration }: Props) {
  const [playing, setPlaying] = useState(false)

  if (playing) return (
    <video src={url} controls autoPlay className="w-full rounded-xl mb-3" style={{maxHeight:'220px'}}/>
  )

  return (
    <div onClick={() => setPlaying(true)}
      className="relative w-full h-32 rounded-xl mb-3 overflow-hidden cursor-pointer bg-[#3C3489] flex items-center justify-center hover:opacity-90 transition">
      {thumbnail && <img src={thumbnail} className="absolute inset-0 w-full h-full object-cover" alt=""/>}
