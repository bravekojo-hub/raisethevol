interface Props { onPublish: (payload: any) => void; publishing: boolean }

export default function TextComposer({ onPublish, publishing }: Props) {
  const [content, setContent] = useState('')
  const [mood, setMood] = useState<Mood | ''>('')
  const [audience, setAudience] = useState<Audience>('everyone')
