'use client'
import { useState, useEffect } from 'react'
import { useProfile } from '@/hooks/useProfile'
import { useRouter } from 'next/navigation'
import Link from 'next/link'

const TOPICS = ['Mental health','Faith & spirituality','Career','Relationships','Family','Joy & celebration','Grief & healing']

export default function EditProfilePage() {
  const { profile, loading, updateProfile } = useProfile()
  const router = useRouter()
  const [form, setForm] = useState({ display_name:'', username:'', bio:'', location:'', website:'', topics:[] as string[] })
  const [saving, setSaving] = useState(false)

  useEffect(() => {
    if (profile) setForm({ display_name: profile.display_name??'', username: profile.username??'', bio: profile.bio??'', location: profile.location??'', website: profile.website??'', topics: profile.topics??[] })
  }, [profile])

  function toggleTopic(t: string) {
    setForm(f => ({ ...f, topics: f.topics.includes(t) ? f.topics.filter(x => x !== t) : [...f.topics, t] }))
  }

  async function save() {
    setSaving(true)
    await updateProfile(form)
    setSaving(false)
    router.push('/profile')
  }

  if (loading) return <div className="p-4"><div className="h-64 bg-gray-100 rounded-2xl animate-pulse"/></div>

  return (
    <div className="p-3.5">
      <div className="flex items-center gap-3 mb-5">
        <Link href="/profile" className="w-8 h-8 bg-[#EEEDFE] rounded-full flex items-center justify-center flex-shrink-0">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#534AB7" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        </Link>
        <h1 className="text-lg font-bold font-syne text-[#1a1a2e]">Edit my profile</h1>
      </div>

      <div className="space-y-3 mb-5">
        {[
          { label: 'Display name', key: 'display_name', placeholder: 'Your name', type: 'text' },
          { label: 'Username', key: 'username', placeholder: 'yourhandle', type: 'text', prefix: '@' },
          { label: 'Location', key: 'location', placeholder: 'City, country...', type: 'text' },
          { label: 'Website', key: 'website', placeholder: 'https://yoursite.com', type: 'url' },
        ].map(f => (
          <div key={f.key}>
            <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1.5">{f.label}</p>
            <div className="relative">
              {f.prefix && <span className="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm">{f.prefix}</span>}
              <input type={f.type} value={(form as any)[f.key]} placeholder={f.placeholder}
                onChange={e => setForm(prev => ({ ...prev, [f.key]: e.target.value }))}
                className={`w-full border border-gray-200 rounded-xl py-2.5 text-sm outline-none focus:border-[#AFA9EC] transition bg-gray-50 ${f.prefix ? 'pl-7 pr-4' : 'px-4'}`}/>
            </div>
          </div>
        ))}

        <div>
          <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1.5">Bio</p>
          <textarea maxLength={160} value={form.bio} onChange={e => setForm(f => ({...f, bio: e.target.value}))} placeholder="Tell the community about yourself..."
            className="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm resize-none outline-none focus:border-[#AFA9EC] transition bg-gray-50 min-h-[80px]"/>
          <p className="text-right text-xs text-gray-400">{form.bio.length}/160</p>
        </div>

        <div>
          <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Topics I speak on</p>
          <div className="flex flex-wrap gap-2">
            {TOPICS.map(t => (
              <button key={t} onClick={() => toggleTopic(t)}
                className={`px-3 py-1.5 rounded-full text-xs border transition ${form.topics.includes(t) ? 'bg-[#EEEDFE] border-[#AFA9EC] text-[#534AB7]' : 'bg-gray-50 border-gray-200 text-gray-500'}`}>
                {t}
              </button>
            ))}
          </div>
        </div>
      </div>

      <button onClick={save} disabled={saving}
        className="w-full bg-[#7F77DD] text-white rounded-xl py-3 font-semibold font-syne text-sm hover:bg-[#534AB7] transition disabled:opacity-50 mb-2">
        {saving ? 'Saving...' : 'Save changes'}
      </button>
      <Link href="/profile" className="block w-full text-center border border-gray-200 rounded-xl py-3 text-sm text-gray-500 hover:bg-gray-50 transition">Cancel</Link>
    </div>
  )
}


