import { useRef, useState } from 'react'
import type { Audience } from '@/types'

interface Props { onPublish: (payload: any, blob: Blob, filename: string) => void; publishing: boolean }

export default function VideoUploader({ onPublish, publishing }: Props) {
  const inputRef = useRef<HTMLInputElement>(null)
  const [file, setFile] = useState<File | null>(null)
  const [preview, setPreview] = useState<string | null>(null)
  const [caption, setCaption] = useState('')
  const [audience, setAudience] = useState<Audience>('everyone')

  function handleFile(f: File) {
    setFile(f); setPreview(URL.createObjectURL(f))
  }

  function submit() {
    if (!file) return
    onPublish({ type: 'video', content: caption, audience, is_anonymous: false }, file, file.name)
  }

  return (
    <div>
      {!preview ? (
        <div onClick={() => inputRef.current?.click()}
          className="border-2 border-dashed border-gray-200 rounded-2xl p-8 text-center cursor-pointer hover:border-[#AFA9EC] hover:bg-[#EEEDFE]/30 transition mb-4">
          <input ref={inputRef} type="file" accept="video/*" className="hidden" onChange={e => e.target.files?.[0] && handleFile(e.target.files[0])}/>
          <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="#9999bb" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round" className="mx-auto mb-2">
            <path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2"/>
          </svg>
          <p className="text-sm font-medium text-[#1a1a2e] mb-1">Tap to record or upload a video</p>
          <p className="text-xs text-gray-400">Up to 5 minutes · Share your story visually</p>
        </div>
      ) : (
        <div className="mb-4">
          <video src={preview} controls className="w-full rounded-xl mb-2 max-h-52"/>
          <button onClick={() => { setFile(null); setPreview(null) }} className="text-xs text-gray-400 hover:text-gray-600">Remove video</button>
        </div>
      )}

      <textarea placeholder="Add a caption (optional)..." value={caption} onChange={e => setCaption(e.target.value)}
        className="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm resize-none outline-none focus:border-[#AFA9EC] transition leading-relaxed min-h-[70px] bg-gray-50 mb-4"/>

      <button onClick={submit} disabled={!file || publishing}
        className="w-full bg-[#7F77DD] text-white rounded-xl py-3 font-semibold font-syne text-sm hover:bg-[#534AB7] transition disabled:opacity-50">
        {publishing ? 'Uploading & publishing...' : 'Publish video'}
      </button>
    </div>
  )
}


