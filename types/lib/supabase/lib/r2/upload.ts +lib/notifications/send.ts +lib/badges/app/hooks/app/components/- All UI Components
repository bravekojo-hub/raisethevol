function Toggle({ on, onToggle }: { on: boolean; onToggle: () => void }) {
  return (
    <button onClick={onToggle} className={`w-[42px] h-6 rounded-full relative transition-colors flex-shrink-0 ${on ? 'bg-[#7F77DD]' : 'bg-gray-200'}`}>
      <span className={`w-[18px] h-[18px] bg-white rounded-full absolute top-[3px] shadow transition-all ${on ? 'left-[21px]' : 'left-[3px]'}`}/>
    </button>
  )
}

export default function NotifPrefsPage() {
  const [prefs, setPrefs] = useState<NotificationPrefs | null>(null)
  const [saving, setSaving] = useState(false)
  const router = useRouter()

  useEffect(() => {
    fetch('/api/notif-prefs').then(r => r.json()).then(d => setPrefs(d.prefs))
  }, [])

  function toggle(key: keyof NotificationPrefs) {
    setPrefs(p => p ? { ...p, [key]: !p[key] } : p)
  }

  async function save() {
    if (!prefs) return
    setSaving(true)
    await fetch('/api/notif-prefs', { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(prefs) })
    setSaving(false)
    router.push('/profile')
  }

  if (!prefs) return <div className="p-4 space-y-2">{[1,2,3].map(i => <div key={i} className="h-14 bg-gray-100 rounded-xl animate-pulse"/>)}</div>

  return (
    <div className="p-3.5">
      <div className="flex items-center gap-3 mb-5">
        <Link href="/profile" className="w-8 h-8 bg-[#EEEDFE] rounded-full flex items-center justify-center flex-shrink-0">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#534AB7" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        </Link>
        <h1 className="text-lg font-bold font-syne text-[#1a1a2e]">Notification preferences</h1>
      </div>

      {/* Master toggle */}
      <div className="bg-[#EEEDFE] border border-[#CECBF6] rounded-2xl px-4 py-3.5 flex items-center justify-between mb-5">
        <div>
          <p className="text-sm font-bold text-[#534AB7] font-syne">All notifications</p>
          <p className="text-xs text-gray-500 mt-0.5">Master on/off switch</p>
        </div>
        <Toggle on={prefs.all_notifs} onToggle={() => toggle('all_notifs')}/>
      </div>

      <div className={prefs.all_notifs ? '' : 'opacity-40 pointer-events-none'}>
        {GROUPS.map(g => (
          <div key={g.label} className="mb-4">
            <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">{g.label}</p>
            <div className="bg-white border border-gray-100 rounded-2xl divide-y divide-gray-100">
              {g.items.map(item => (
                <div key={item.key} className="flex items-center justify-between px-4 py-3 gap-3">
                  <div className="flex-1 min-w-0">
                    <p className="text-sm font-medium text-[#1a1a2e]">{item.title}</p>
                    <p className="text-xs text-gray-400 mt-0.5 leading-snug">{item.sub}</p>
                  </div>
                  <Toggle on={!!prefs[item.key]} onToggle={() => toggle(item.key)}/>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <button onClick={save} disabled={saving}
        className="w-full bg-[#7F77DD] text-white rounded-xl py-3 font-semibold font-syne text-sm hover:bg-[#534AB7] transition disabled:opacity-50 mt-2 mb-2">
        {saving ? 'Saving...' : 'Save preferences'}
      </button>
      <Link href="/profile" className="block w-full text-center border border-gray-200 rounded-xl py-3 text-sm text-gray-500 hover:bg-gray-50 transition">Cancel</Link>
    </div>
  )
}
