'use client'
import { useState } from 'react'
import { useFeed } from '@/hooks/useFeed'
import PostCard from '@/components/feed/PostCard'
import FeedFilter from '@/components/feed/FeedFilter'
import type { FeedFilter as FF } from '@/types'

export default function FeedPage() {
  const [filter, setFilter] = useState<FF>({ type: 'all' })
  const { posts, loading, loadingMore, hasMore, fetchMore, toggleEncourage, toggleLike } = useFeed(filter)

  return (
    <div className="p-3.5">
      <FeedFilter current={filter.type} onChange={t => setFilter({ type: t })} />
      {loading ? (
        <div className="space-y-3">
          {[1,2,3].map(i => <div key={i} className="h-48 bg-gray-100 rounded-2xl animate-pulse"/>)}
        </div>
      ) : posts.length === 0 ? (
        <div className="text-center py-20 text-gray-400">
          <p className="text-lg font-semibold">No voices yet</p>
          <p className="text-sm mt-1">Be the first to speak in this space.</p>
        </div>
      ) : (
        <div className="space-y-3">
          {posts.map(post => (
            <PostCard key={post.id} post={post}
              onEncourage={() => toggleEncourage(post.id)}
              onLike={() => toggleLike(post.id)} />
          ))}
          {hasMore && (
            <button onClick={fetchMore} disabled={loadingMore}
              className="w-full py-3 text-sm text-[#7F77DD] font-medium disabled:opacity-50">
              {loadingMore ? 'Loading...' : 'Load more voices'}
            </button>
          )}
        </div>
      )}
    </div>
  )
}


