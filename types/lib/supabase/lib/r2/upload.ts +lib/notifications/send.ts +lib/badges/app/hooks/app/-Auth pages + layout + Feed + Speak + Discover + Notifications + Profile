'use client'
import { useState } from 'react'
import TextComposer from '@/components/speak/TextComposer'
import VoiceRecorder from '@/components/speak/VoiceRecorder'
import VideoUploader from '@/components/speak/VideoUploader'
import { uploadBlobToR2 } from '@/lib/r2/upload'
import { useRouter } from 'next/navigation'

type Tab = 'text' | 'voice' | 'video'

export default function SpeakPage() {
  const [tab, setTab] = useState<Tab>('text')
  const [publishing, setPublishing] = useState(false)
  const [success, setSuccess] = useState(false)
  const router = useRouter()

  async function publish(payload: any, blob?: Blob, filename?: string) {
    setPublishing(true)
    let media_url: string | undefined
    if (blob && filename) media_url = await uploadBlobToR2(blob, filename)

    await fetch('/api/posts', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ...payload, media_url }),
    })
    setPublishing(false)
    setSuccess(true)
    setTimeout(() => { setSuccess(false); router.push('/feed') }, 2500)
  }

  const tabs: { key: Tab; label: string }[] = [
    { key: 'text', label: 'Write it' },
    { key: 'voice', label: 'Voice note' },
    { key: 'video', label: 'Video' },
  ]

  return (
    <div className="p-3.5">
      {/* Hero */}
      <div className="bg-[#3C3489] rounded-2xl p-5 mb-4 text-center">
        <div className="w-14 h-14 bg-[#7F77DD] rounded-full flex items-center justify-center mx-auto mb-3 border-2 border-[#AFA9EC]">
          <svg viewBox="0 0 28 28" width="26" height="26" fill="none">
            <path d="M5 11v6h4l8 6V5L9 11H5z" fill="white" stroke="white" strokeWidth="1"/>
            <path d="M17 10.5c2 1.2 3.2 2.8 3.2 4.5s-1.2 3.3-3.2 4.5" stroke="rgba(255,255,255,0.7)" strokeWidth="1.8" strokeLinecap="round"/>
          </svg>
        </div>
        <h2 className="text-white font-bold text-xl font-syne mb-1">Raise your voice</h2>
        <p className="text-white/60 text-sm leading-relaxed">Pour it out. Your words matter here.<br/>Someone needs to hear exactly what you have to say.</p>
      </div>

      {/* Tabs */}
      <div className="flex gap-2 mb-4 flex-wrap">
        {tabs.map(t => (
          <button key={t.key} onClick={() => setTab(t.key)}
            className={`px-4 py-1.5 rounded-full text-sm border transition ${tab === t.key ? 'bg-[#EEEDFE] border-[#AFA9EC] text-[#534AB7] font-medium' : 'bg-gray-50 border-gray-200 text-gray-500'}`}>
            {t.label}
          </button>
        ))}
      </div>

      {tab === 'text' && <TextComposer onPublish={publish} publishing={publishing} />}
      {tab === 'voice' && <VoiceRecorder onPublish={publish} publishing={publishing} />}
      {tab === 'video' && <VideoUploader onPublish={publish} publishing={publishing} />}

      {success && (
        <div className="bg-[#E1F5EE] border border-[rgba(29,158,117,0.3)] rounded-xl p-4 text-center mt-4">
          <p className="text-[#0F6E56] font-bold font-syne text-base">Your voice is out there!</p>
          <p className="text-[#085041] text-sm mt-1">Thank you for sharing. The community will hear you.</p>
        </div>
      )}
    </div>
  )
}


