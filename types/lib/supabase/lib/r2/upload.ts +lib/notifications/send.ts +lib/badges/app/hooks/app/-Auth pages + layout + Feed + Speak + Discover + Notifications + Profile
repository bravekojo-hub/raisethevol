'use client'
import { useEffect, useState } from 'react'
import { formatDistanceToNow } from 'date-fns'
import type { Notification } from '@/types'

const NOTIF_COLORS: Record<string, string> = {
  encourage: 'bg-[#7F77DD]', like: 'bg-[#D4537E]', reply: 'bg-[#7F77DD]',
  follow: 'bg-[#1D9E75]', trending: 'bg-[#1D9E75]', milestone: 'bg-[#BA7517]',
}

export default function NotificationsPage() {
  const [notifs, setNotifs] = useState<Notification[]>([])
  const [loading, setLoading] = useState(true)

  useEffect(() => {
    fetch('/api/notifications').then(r => r.json()).then(d => {
      setNotifs(d.notifications ?? [])
      setLoading(false)
      // Mark all as read
      fetch('/api/notifications', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: 'all' }),
      })
    })
  }, [])

  if (loading) return <div className="p-4 space-y-3">{[1,2,3,4].map(i => <div key={i} className="h-16 bg-gray-100 rounded-xl animate-pulse"/>)}</div>

  return (
    <div className="p-3.5">
      <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Recent alerts</p>
      {notifs.length === 0 ? (
        <div className="text-center py-20 text-gray-400">
          <p>No notifications yet</p>
          <p className="text-sm mt-1">When someone encourages or replies to you, you'll see it here.</p>
        </div>
      ) : (
        <div className="divide-y divide-gray-100">
          {notifs.map(n => (
            <div key={n.id} className={`flex gap-3 py-3.5 ${!n.is_read ? 'opacity-100' : 'opacity-65'}`}>
              <div className={`w-2 h-2 rounded-full mt-1.5 flex-shrink-0 ${NOTIF_COLORS[n.type] ?? 'bg-gray-300'}`}/>
              <div className="flex-1">
                <p className="text-sm text-[#1a1a2e] leading-snug">
                  {n.actor && <strong className="font-medium">{n.actor.display_name} </strong>}
                  {n.message ?? n.type}
                </p>
                <p className="text-xs text-gray-400 mt-1">
                  {formatDistanceToNow(new Date(n.created_at), { addSuffix: true })}
                </p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )
}


