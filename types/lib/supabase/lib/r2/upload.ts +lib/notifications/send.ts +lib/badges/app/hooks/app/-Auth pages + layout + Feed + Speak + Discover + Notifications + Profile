'use client'
import { useProfile } from '@/hooks/useProfile'
import { useAuth } from '@/hooks/useAuth'
import Link from 'next/link'

const BADGE_LABELS: Record<string, string> = {
  first_voice: 'First voice — you took the leap',
  hundred_encouragements: '100 encouragements given',
  joy_spreader: 'Spreader of joy',
}

export default function ProfilePage() {
  const { profile, badges, loading } = useProfile()
  const { signOut } = useAuth()

  if (loading) return <div className="p-4 space-y-3"><div className="h-48 bg-gray-100 rounded-2xl animate-pulse"/></div>
  if (!profile) return null

  return (
    <div className="p-3.5">
      {/* Profile header */}
      <div className="bg-[#3C3489] rounded-2xl p-6 text-center mb-3.5">
        {profile.avatar_url
          ? <img src={profile.avatar_url} className="w-18 h-18 rounded-full mx-auto mb-3 border-3 border-[#AFA9EC] object-cover" alt=""/>
          : <div className="w-[72px] h-[72px] rounded-full bg-[#7F77DD] flex items-center justify-center text-white text-2xl font-bold font-syne mx-auto mb-3 border-3 border-[#AFA9EC]">
              {profile.display_name?.slice(0,2).toUpperCase()}
            </div>
        }
        <h2 className="text-white text-xl font-bold font-syne mb-1">{profile.display_name}</h2>
        <p className="text-white/60 text-sm leading-relaxed">{profile.bio ?? 'No bio yet.'}</p>
      </div>

      {/* Stats */}
      <div className="grid grid-cols-3 gap-2 mb-3.5">
        {[
          { n: profile.voices_count, l: 'Voices shared' },
          { n: profile.encouragements_received, l: 'Encouragements' },
          { n: profile.followers_count, l: 'Followers' },
        ].map(s => (
          <div key={s.l} className="bg-gray-50 rounded-xl p-3 text-center">
            <p className="text-xl font-bold font-syne text-[#1a1a2e]">{s.n.toLocaleString()}</p>
            <p className="text-xs text-gray-400 mt-0.5">{s.l}</p>
          </div>
        ))}
      </div>

      {/* Badges */}
      {badges.length > 0 && (
        <>
          <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Earned badges</p>
          <div className="space-y-2 mb-3.5">
            {badges.map(b => (
              <div key={b.id} className="flex items-center gap-2 bg-[#EEEDFE] rounded-xl px-3 py-2.5 text-sm text-[#534AB7]">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                {BADGE_LABELS[b.badge_key] ?? b.badge_key}
              </div>
            ))}
          </div>
        </>
      )}

      {/* Settings */}
      <p className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Settings</p>
      <div className="space-y-2">
        <Link href="/profile/edit" className="block w-full text-center border border-gray-200 rounded-xl py-3 text-sm text-gray-600 hover:bg-gray-50 transition">Edit my profile</Link>
        <Link href="/profile/notif-prefs" className="block w-full text-center border border-gray-200 rounded-xl py-3 text-sm text-gray-600 hover:bg-gray-50 transition">Notification preferences</Link>
        <Link href="/privacy" className="block w-full text-center border border-gray-200 rounded-xl py-3 text-sm text-gray-600 hover:bg-gray-50 transition">Privacy &amp; safety</Link>
        <button onClick={signOut} className="w-full border border-[rgba(216,90,48,0.2)] rounded-xl py-3 text-sm text-[#D85A30] hover:bg-[#FAECE7] transition">Sign out</button>
      </div>
    </div>
  )
}
